# AI Learning Assistant Configuration
# Copy this to .env and add your API key

# Option 1: Google Gemini (FREE - RECOMMENDED)
# Get it from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Claude (Requires Credits)
# Get it from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: Override default settings
# AI_PROVIDER=auto            # auto | gemini | anthropic
# GEMINI_MODEL=gemini-2.0-flash
# AI_STRICT_MODE=false        # true => disable rule-based fallback; require real AI response
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# VECTOR_DB_PATH=./vector_db
# MAX_CONTEXT_DOCS=3
# AI_TEMPERATURE=0.7
